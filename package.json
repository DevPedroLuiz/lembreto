{
  "name": "lembreto",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env.local server.ts",
    "dev:e2e": "tsx scripts/start-e2e-server.ts",
    "start": "tsx --env-file=.env.local server.ts",
    "build": "vite build",
    "migrate": "tsx scripts/run-migrations.ts",
    "vercel-build": "vite build",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit",
    "mobile:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:run": "npm run mobile:sync && cap run android",
    "android:build": "npm run mobile:sync && cap build android",
    "android:release": "npm run mobile:sync && cd android && gradlew assembleRelease bundleRelease",
    "scheduler:notifications": "node scheduler/notification-scheduler.mjs",
    "scheduler:check": "node --check scheduler/notification-scheduler.mjs",
    "setup:test-db": "tsx scripts/setup-test-db.ts",
    "test": "tsx --env-file=.env.local scripts/run-tests.ts",
    "test:e2e": "playwright test",
    "cleanup:db": "tsx --env-file=.env.local scripts/cleanup-db.ts"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "^8.0.0",
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.0",
    "@google/genai": "^2.6.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-holidays": "^3.27.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0",
    "vite": "^6.2.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@playwright/test": "^1.59.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@vercel/node": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
