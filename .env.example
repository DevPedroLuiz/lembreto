DATABASE_URL=
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
APP_URL=http://localhost:3001
# Optional for native/mobile builds. Leave empty on same-origin web deploys.
VITE_API_BASE_URL=https://api.lembreto.com
# Native Google OAuth callback handled by the Android app intent filter.
MOBILE_GOOGLE_REDIRECT_URL=com.lembreto.app://auth/google/callback
# Optional comma-separated web origins allowed to call the API when it is on another domain.
CORS_ALLOWED_ORIGINS=https://app.lembreto.com
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALENDAR_CLIENT_ID=your_google_calendar_oauth_client_id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_calendar_oauth_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3001/api/calendar/google/callback
OUTLOOK_CLIENT_ID=your_outlook_application_client_id
OUTLOOK_CLIENT_SECRET=your_outlook_client_secret
OUTLOOK_REDIRECT_URI=http://localhost:3001/api/calendar/outlook/callback
CALENDAR_TOKEN_ENCRYPTION_KEY=optional_64_hex_or_long_random_secret
VITE_RECAPTCHA_SITE_KEY=your_google_recaptcha_v2_site_key
# Optional runtime fallback used by /api/auth/config when the Vite build env is unavailable.
RECAPTCHA_SITE_KEY=your_google_recaptcha_v2_site_key
RECAPTCHA_SECRET_KEY=your_google_recaptcha_v2_secret_key
CRON_SECRET=replace_with_a_second_long_random_secret
VAPID_PUBLIC_KEY=replace_with_the_public_vapid_key
VAPID_PRIVATE_KEY=replace_with_the_private_vapid_key
VAPID_SUBJECT=mailto:seu-email@example.com
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MERCADO_PAGO_WEBHOOK_SECRET=replace_with_mercado_pago_webhook_secret
MERCADO_PAGO_CURRENCY=BRL
MERCADO_PAGO_PRO_MONTHLY_AMOUNT=29.90
MERCADO_PAGO_TEAM_MONTHLY_AMOUNT=79.90
MERCADO_PAGO_WEBHOOK_URL=https://api.lembreto.com/api/billing/webhook
MERCADO_PAGO_SUBSCRIPTIONS_URL=https://www.mercadopago.com.br/subscriptions
MIGRATION_LOCK_TIMEOUT=10s
MIGRATION_STATEMENT_TIMEOUT=5min
