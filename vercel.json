{
  "version": 2,
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/auth/register", "destination": "/api/auth/register" },
    { "source": "/api/auth/login",    "destination": "/api/auth/login"    },
    { "source": "/api/auth/recover",  "destination": "/api/auth/recover"  },
    { "source": "/api/auth/profile",  "destination": "/api/auth/profile"  },
    { "source": "/api/tasks/:id",     "destination": "/api/tasks/[id]"    },
    { "source": "/api/tasks",         "destination": "/api/tasks/index"   },
    { "source": "/(.*)",              "destination": "/index.html"        }
  ]
}
